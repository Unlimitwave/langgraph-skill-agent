# Copy to .env and fill in values: cp .env.example .env
#
# Required for agent / UI / plan / summary
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# RAG: embedding service (OpenAI-compatible /v1/embeddings)
EMBED_BASE_URL=http://127.0.0.1:8080/v1
EMBED_API_KEY=dummy
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# RAG: Milvus vector store（通常为远程稳定服务；Docker app 容器内勿用 127.0.0.1）
MILVUS_URI=http://your-remote-milvus-host:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=rag_llamaindex
MILVUS_METRIC=IP
MILVUS_RRF_K=60
RAG_TOP_K=8
RAG_FORCE_REBUILD=0  # 1=强制重建索引（删本地 storage 并 drop Milvus collection），0=有缓存则加载

# Optional: MCP tools (embedded FastMCP when MCP_CLIENT_URL is empty)
MCP_TOOLS=1  # 1=启用 MCP 工具，0=关闭
MCP_CLIENT_URL=
MCP_TOOL_NAME_PREFIX=mcp_

# Optional: conversation / routing
THREAD_ID=demo-thread-1
MACRO_THREAD_ID=
ENABLE_PLAN_ROUTING=0  # 1=CLI 复杂任务自动路由到规划流程plan模式，0=关闭

# Optional: context compaction (default enabled)
COMPACT_ENABLED=1
COMPACT_MAX_CONTEXT_TOKENS=60000
COMPACT_RESERVE_TOKENS=8000
COMPACT_TAIL_MESSAGES=32
COMPACT_SYSTEM_OVERHEAD_TOKENS=3500

# Optional: summary CLI
SUMMARY_MAX_TRANSCRIPT_CHARS=48000

# Optional: paths (defaults under ./var and ./skills)
# PROJECT_ROOT=
# AGENT_MEMORY_DIR=
# RAG_DATA_DIR=
# RAG_STORAGE_DIR=
# CONVERSATION_HISTORY_DIR=
# SKILLS_DIR=

# Optional: diagnostics
LOG_LEVEL=INFO
RAG_TRACE=0  # 1=输出 RAG/MCP 调试日志，0=关闭
AGENT_TOOL_TRACE=1 # 1=输出 Agent 工具调用调试日志，0=关闭

# Optional: Docker Compose
# APP_PORT=8501
# DOCKER_VOLUME_DIRECTORY=./deploy/volumes   # 仅 make docker-up-milvus 本地 Milvus 时用
# IMAGE=registry.example.com/langgraph-skill-agent
# TAG=abc1234
# 容器内访问宿主机 Embedding：EMBED_BASE_URL=http://host.docker.internal:8080/v1
