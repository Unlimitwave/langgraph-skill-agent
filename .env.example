# Copy to .env and fill in values: cp .env.example .env
#
# Required for agent / UI / plan / summary
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# RAG: embedding service (OpenAI-compatible /v1/embeddings)
EMBED_BASE_URL=http://127.0.0.1:8080/v1
EMBED_API_KEY=dummy
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# RAG: Milvus vector store（通常为远程稳定服务；Docker app 容器内勿用 127.0.0.1）
MILVUS_URI=http://your-remote-milvus-host:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=rag_llamaindex
MILVUS_METRIC=IP
MILVUS_RRF_K=60
RAG_TOP_K=8
RAG_FORCE_REBUILD=0  # 1=强制重建索引（删本地 storage 并 drop Milvus collection），0=有缓存则加载

# Optional: MCP tools (embedded FastMCP when MCP_CLIENT_URL is empty)
MCP_TOOLS=1  # 1=启用 MCP 工具，0=关闭
MCP_CLIENT_URL=
MCP_TOOL_NAME_PREFIX=mcp_

# Optional: conversation / routing
THREAD_ID=demo-thread-1
MACRO_THREAD_ID=
ENABLE_INTENT_ROUTING=1  # 1=每轮 LLM 意图路由；0=固定走下方已启用的编排模式（MULTI_AGENT 优先于 PLAN）
ENABLE_PLAN_ROUTING=0  # 1=启用 plan 编排；Intent 开时由路由判定，Intent 关时仅在没有 MULTI_AGENT 时生效
ENABLE_MULTI_AGENT_ROUTING=0  # 1=启用 Supervisor 多智能体；Intent 关时每轮固定走 Supervisor（优先于 PLAN）
SUPERVISOR_MAX_REVIEW_RETRIES=2  # Review 不通过时 Worker 最大重试次数

# Checkpointer（生产默认 postgres；本地无 PG 可改为 sqlite 或 memory）
POSTGRES_PASSWORD=your-strong-password
CHECKPOINT_BACKEND=postgres
# 同实例 Postgres、分库隔离：Docker app ↔ langgraph_docker，裸机 run-ui ↔ langgraph_local
POSTGRES_DB_DOCKER=langgraph_docker
POSTGRES_DB_LOCAL=langgraph_local
POSTGRES_URI=postgresql://langgraph:your-strong-password@localhost:5432/langgraph_local
# Docker 容器内 app 由 docker-compose.prod.yml 覆盖为 @postgres:5432/langgraph_docker
# 首次 / 升级后：make postgres-init-dbs（docker-stack-up 会自动执行）
# POSTGRES_PUBLISH_PORT=5432   # Postgres 映射到宿主机 127.0.0.1:5432
# CHECKPOINT_BACKEND=sqlite
# CHECKPOINT_BACKEND=memory
# POSTGRES_POOL_MAX=10
# HYDRATE_ENABLED=0          # 1=空 thread 时从 JSON 灾备恢复（非热路径）
# CHECKPOINT_EXPORT_SNAPSHOT=0 # 1=每轮额外导出 var/conversation_history/*.json

# Optional: context budget + compaction (defaults align with 128K models)
# CONTEXT_WINDOW=128000
# CONTEXT_INPUT_BUDGET_RATIO=0.70
# CONTEXT_SYSTEM_BUDGET_RATIO=0.35
# CONTEXT_RESERVE_TOKENS=8000   # 预留给本轮回复 + 工具输出（compactor / rolling window）
COMPACT_ENABLED=1
COMPACT_TAIL_MESSAGES=32

# Optional: enterprise working-memory pruning (before_model + wrap_tool_call)
# CONTEXT_PRUNE_ENABLED=1
# CONTEXT_PRUNE_TRACE=0
# TOOL_OUTPUT_MAX_TOKENS=2000
# TOOL_ARGS_MAX_TOKENS=800
# TOOL_ARGS_KEEP_RECENT_MESSAGES=12
# ROLLING_WINDOW_MAX_TURNS=0   # 0=仅按 token 预算滚动；>0 时硬顶保留最近 N 轮 Human 对话

# Optional: summary CLI
SUMMARY_MAX_TRANSCRIPT_CHARS=48000

# Optional: prompt registry (manifest: src/langgraph_skill_agent/prompts/manifest.json)
# PROMPT_DEFAULT_VERSION=v1
# PROMPT_AGENT_SYSTEM_VERSION=v1
# PROMPT_INTENT_ROUTER_VERSION=v1

# Optional: paths (defaults under ./var, ./skills, ./workspace)
# PROJECT_ROOT=
# AGENT_MEMORY_DIR=
# RAG_DATA_DIR=
# RAG_STORAGE_DIR=
# CONVERSATION_HISTORY_DIR=
# SKILLS_DIR=              # platform system skills (on-disk; mounted read-only at /system-skills/)
# WORKSPACE_DIR=           # per-user sandboxes root; default ./workspace
# AGENT_USER_ID=default    # CLI / single-tenant UI override; leave unset for per-browser UI tenants
# AGENT_TENANT_ID=default  # Runtime Context tenant_id (multi-tenant org isolation)

# Optional: diagnostics
LOG_LEVEL=INFO
RAG_TRACE=0  # 1=输出 RAG/MCP 调试日志，0=关闭
AGENT_TOOL_TRACE=1 # 1=输出 Agent 工具调用调试日志，0=关闭

# Optional: Docker Compose
# APP_PORT=8501
# DOCKER_VOLUME_DIRECTORY=./deploy/volumes   # 仅 make docker-up-milvus 本地 Milvus 时用
# IMAGE=registry.example.com/langgraph-skill-agent
# TAG=abc1234
# 容器内访问宿主机 Embedding：EMBED_BASE_URL=http://host.docker.internal:8080/v1
